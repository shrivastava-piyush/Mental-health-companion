<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Splash / bootstrap theme. Compose drives in-app theming so we only need
        an edge-to-edge translucent splash theme here.
    -->
    <style name="Theme.WellnessCompanion" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/cream</item>
        <item name="android:statusBarColor">@color/cream</item>
        <item name="android:navigationBarColor">@color/cream</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>
</resources>
